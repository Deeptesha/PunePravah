# PunePravah Environment Configuration Example
# Copy this file to .env and configure real credentials

# IMD API Endpoint Configuration
IMD_API_URL=https://api.weather.gov.in/alerts/active

# OpenWeather API Configuration
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# PMC Open Data Portal (Dam & Waterlogging Telemetry)
PMC_OPEN_DATA_URL=https://opendata.punecorporation.org/api/dam-levels
